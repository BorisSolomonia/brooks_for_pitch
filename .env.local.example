# Local development overrides (copy to .env.local)
# These are loaded by Vite because vite.config.ts sets envDir: ".."

# Override API URLs for local services (optional — defaults fall back to VITE_PINS_API_URL + /auth or /social)
# VITE_AUTH_API_URL=http://localhost:8081
# VITE_SOCIAL_API_URL=http://localhost:8082
# VITE_PINS_API_URL=http://localhost:8084

# Override Auth0 redirect for local dev
# VITE_AUTH0_REDIRECT_URI=http://localhost:5173

# Use Leaflet instead of Google Maps locally (no API key needed)
# VITE_MAP_PROVIDER=leaflet
