# Brooks App — origin server behind Cloudflare
#
# Supports both Cloudflare SSL modes without ACME/Let's Encrypt:
#   Flexible     → Cloudflare connects to origin on :80  (HTTP)
#   Full         → Cloudflare connects to origin on :443 (self-signed TLS)
#   Full Strict  → requires a Cloudflare Origin Certificate (not set up here)
#
# auto_https off prevents Caddy from requesting Let's Encrypt certs.
# tls internal  uses Caddy's built-in CA for a self-signed cert on :443.
# Neither hits any rate limit.

{
  auto_https off
}

# ── Shared routes (imported by both HTTP and HTTPS blocks) ──────────────────
(app_routes) {
  encode gzip zstd

  # Lightweight health check — deploy pipeline and load balancers use this
  @health path /health
  respond @health "OK" 200

  # API routes
  handle_path /api/auth/* {
    reverse_proxy auth-service:8081
  }

  handle_path /api/social/* {
    reverse_proxy social-service:8082
  }

  handle_path /api/lists/* {
    reverse_proxy lists-service:8083
  }

  # Strip /api so pins-service receives /pins/...
  handle /api/pins* {
    uri strip_prefix /api
    reverse_proxy pins-service:8084
  }

  handle_path /api/media/* {
    reverse_proxy media-service:8085
  }

  handle_path /api/moderation/* {
    reverse_proxy moderation-service:8086
  }

  handle_path /api/notifications/* {
    reverse_proxy notifications-service:8087
  }

  # Management actuator (primary = pins-service)
  handle /actuator/* {
    reverse_proxy pins-service:8084
  }

  # React SPA — catch-all
  handle {
    reverse_proxy frontend:3000
  }

  header {
    -Server
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    X-XSS-Protection "1; mode=block"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "accelerometer=(), camera=(), geolocation=(self), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
  }
}

# ── HTTP — Cloudflare "Flexible" SSL ────────────────────────────────────────
http://{$BROOKS_DOMAIN}, http://www.{$BROOKS_DOMAIN}, :80 {
  log {
    output stdout
    format console
    level INFO
  }
  import app_routes
}

# ── HTTPS — Cloudflare "Full" SSL (self-signed cert, no ACME) ───────────────
https://{$BROOKS_DOMAIN}, https://www.{$BROOKS_DOMAIN} {
  log {
    output stdout
    format console
    level INFO
  }
  tls internal
  import app_routes
}
