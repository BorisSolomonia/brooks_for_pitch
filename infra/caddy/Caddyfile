# Brooks App — origin server behind Cloudflare
#
# SSL modes:
#   Flexible    → Cloudflare connects to origin on :80  (HTTP only)
#   Full        → Cloudflare connects on :443, accepts any cert
#   Full Strict → Cloudflare connects on :443, requires a valid cert
#                 ✅ we use a Cloudflare Origin Certificate for this
#
# auto_https off  — disables ACME/Let's Encrypt (Cloudflare handles public TLS)
# tls <cert> <key> — uses the Cloudflare Origin Certificate mounted at deploy time

{
  auto_https off
}

# ── Shared routes (imported by both HTTP and HTTPS blocks) ──────────────────
(app_routes) {
  encode gzip zstd

  # Lightweight health check — deploy pipeline and load balancers use this
  @health path /health
  respond @health "OK" 200

  # API routes
  handle_path /api/auth/* {
    reverse_proxy auth-service:8081
  }

  handle_path /api/social/* {
    reverse_proxy social-service:8082
  }

  handle_path /api/lists/* {
    reverse_proxy lists-service:8083
  }

  # Strip /api so pins-service receives /pins/...
  handle /api/pins* {
    uri strip_prefix /api
    reverse_proxy pins-service:8084
  }

  handle_path /api/media/* {
    reverse_proxy media-service:8085
  }

  handle_path /api/moderation/* {
    reverse_proxy moderation-service:8086
  }

  handle_path /api/notifications/* {
    reverse_proxy notifications-service:8087
  }

  # Management actuator (primary = pins-service)
  handle /actuator/* {
    reverse_proxy pins-service:8084
  }

  # React SPA — catch-all
  handle {
    reverse_proxy frontend:3000
  }

  header {
    -Server
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    X-XSS-Protection "1; mode=block"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "accelerometer=(), camera=(), geolocation=(self), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
  }
}

# ── HTTP — Cloudflare "Flexible" SSL ────────────────────────────────────────
http://{$BROOKS_DOMAIN}, http://www.{$BROOKS_DOMAIN}, :80 {
  log {
    output stdout
    format console
    level INFO
  }
  import app_routes
}

# ── HTTPS — Cloudflare "Full Strict" (Origin Certificate, no ACME) ──────────
https://{$BROOKS_DOMAIN}, https://www.{$BROOKS_DOMAIN} {
  log {
    output stdout
    format console
    level INFO
  }
  tls /etc/caddy/origin.crt /etc/caddy/origin.key
  import app_routes
}
