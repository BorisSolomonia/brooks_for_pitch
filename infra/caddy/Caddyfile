# Brooks App origin server behind Cloudflare
# Cloudflare handles public TLS; Caddy terminates the origin certificate only.

{
  auto_https off
}

(app_routes) {
  encode gzip zstd

  @health path /health
  respond @health "OK" 200

  handle_path /api/auth/* {
    reverse_proxy {$AUTH_SERVICE_HOST}:{$AUTH_SERVICE_PORT}
  }

  handle_path /api/social/* {
    reverse_proxy {$SOCIAL_SERVICE_HOST}:{$SOCIAL_SERVICE_PORT}
  }

  handle_path /api/lists/* {
    reverse_proxy {$LISTS_SERVICE_HOST}:{$LISTS_SERVICE_PORT}
  }

  handle /api/pins* {
    uri strip_prefix /api
    reverse_proxy {$PINS_SERVICE_HOST}:{$PINS_SERVICE_PORT}
  }

  handle_path /api/media/* {
    reverse_proxy {$MEDIA_SERVICE_HOST}:{$MEDIA_SERVICE_PORT}
  }

  handle_path /api/moderation/* {
    reverse_proxy {$MODERATION_SERVICE_HOST}:{$MODERATION_SERVICE_PORT}
  }

  handle_path /api/notifications/* {
    reverse_proxy {$NOTIFICATIONS_SERVICE_HOST}:{$NOTIFICATIONS_SERVICE_PORT}
  }

  handle /actuator/* {
    reverse_proxy {$PINS_SERVICE_HOST}:{$PINS_SERVICE_PORT}
  }

  handle {
    reverse_proxy {$FRONTEND_HOST}:{$FRONTEND_PORT}
  }

  header {
    -Server
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    X-XSS-Protection "1; mode=block"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "accelerometer=(), camera=(), geolocation=(self), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
  }
}

http://{$BROOKS_DOMAIN}, http://www.{$BROOKS_DOMAIN}, :80 {
  log {
    output stdout
    format console
    level INFO
  }
  import app_routes
}

https://{$BROOKS_DOMAIN}, https://www.{$BROOKS_DOMAIN} {
  log {
    output stdout
    format console
    level INFO
  }
  tls /etc/caddy/origin.crt /etc/caddy/origin.key
  import app_routes
}
