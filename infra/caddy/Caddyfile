# Brooks App - Cloudflare-terminated SSL
# Cloudflare handles TLS. Caddy serves plain HTTP on :80.
# Cloudflare SSL mode should be "Flexible" (connects to origin on HTTP).
# If you ever switch to "Full/Full-Strict" you need a Cloudflare Origin
# Certificate and a tls block in the site block below.

{
  # Disable automatic HTTPS — Cloudflare is the TLS terminator.
  # Without this Caddy tries ACME on every startup, hits Let's Encrypt
  # rate limits (5 certs/domain/week) after a few redeploys and fails.
  auto_https off
}

http://{$BROOKS_DOMAIN}, http://www.{$BROOKS_DOMAIN}, :80 {
  log {
    output stdout
    format console
    level INFO
  }

  # Enable gzip and zstd compression
  encode gzip zstd

  # Lightweight health check for deploy pipeline and load balancers
  @health path /health
  respond @health "OK" 200

  # ── API routes ────────────────────────────────────────────────────────────

  handle_path /api/auth/* {
    reverse_proxy auth-service:8081
  }

  handle_path /api/social/* {
    reverse_proxy social-service:8082
  }

  handle_path /api/lists/* {
    reverse_proxy lists-service:8083
  }

  # /api/pins* — strip only /api so service receives /pins/...
  handle /api/pins* {
    uri strip_prefix /api
    reverse_proxy pins-service:8084
  }

  handle_path /api/media/* {
    reverse_proxy media-service:8085
  }

  handle_path /api/moderation/* {
    reverse_proxy moderation-service:8086
  }

  handle_path /api/notifications/* {
    reverse_proxy notifications-service:8087
  }

  # Actuator (primary = pins-service)
  handle /actuator/* {
    reverse_proxy pins-service:8084
  }

  # ── Frontend (React SPA) ─────────────────────────────────────────────────
  handle {
    reverse_proxy frontend:3000
  }

  # ── Security headers ──────────────────────────────────────────────────────
  header {
    -Server
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    X-XSS-Protection "1; mode=block"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "accelerometer=(), camera=(), geolocation=(self), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
  }
}
