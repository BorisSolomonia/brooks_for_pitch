# Production runtime env for Brooks
# This file documents the variables that should exist in Secret Manager.
# Image tags are injected by CI into .env.runtime and should not live in the secret.

# Auth0
BROOKS_DOMAIN=brooksweb.uk
AUTH0_ISSUER_URI=https://your-tenant.us.auth0.com/
AUTH0_AUDIENCE=https://api.brooksweb.uk
BROOKS_WEB_ORIGINS=https://brooksweb.uk

# Internal service auth
INTERNAL_SERVICE_NAME=pins-service
INTERNAL_SERVICE_KEY=replace-me
INTERNAL_SERVICE_KEYS=pins-service=replace-me
INTERNAL_SERVICE_ALLOWED_NAMES=pins-service
INTERNAL_SERVICE_KEY_MAP=pins-service=replace-me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-me
REDIS_CACHE_TTL_SECONDS=60

# Databases
AUTH_DB_URL=jdbc:postgresql://host:5432/auth_db?sslmode=require
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=replace-me
SOCIAL_DB_URL=jdbc:postgresql://host:5432/social_db?sslmode=require
SOCIAL_DB_USER=social_user
SOCIAL_DB_PASSWORD=replace-me
LISTS_DB_URL=jdbc:postgresql://host:5432/lists_db?sslmode=require
LISTS_DB_USER=lists_user
LISTS_DB_PASSWORD=replace-me
PINS_DB_URL=jdbc:postgresql://host:5432/pins_db?sslmode=require
PINS_DB_USER=pins_user
PINS_DB_PASSWORD=replace-me
MODERATION_DB_URL=jdbc:postgresql://host:5432/moderation_db?sslmode=require
MODERATION_DB_USER=moderation_user
MODERATION_DB_PASSWORD=replace-me

# Service-to-service URLs inside Docker network
SOCIAL_SERVICE_URL=http://social-service:8082
LISTS_SERVICE_URL=http://lists-service:8083

# Auth service JWT
BROOKS_JWT_ISSUER=brooks
BROOKS_JWT_SECRET=replace-me
BROOKS_JWT_ACCESS_TTL=900
BROOKS_JWT_REFRESH_TTL=2592000

# Pins service
BROOKS_BUCKET_SIZE_DEG=0.01
BROOKS_CLEANUP_ENABLED=true
BROOKS_CLEANUP_BATCH_SIZE=1000
BROOKS_CLEANUP_RETENTION_DAYS=7
BROOKS_CLEANUP_CRON=0 0 2 * * ?

# Media
MEDIA_UPLOAD_BASE_URL=https://upload.example.com

# Runtime tuning defaults
DB_MAX_POOL_SIZE=1
DB_MIN_IDLE=0
DB_CONNECTION_TIMEOUT_MS=60000
FLYWAY_CONNECT_RETRIES=30

# Frontend build-time vars consumed by CI when building the image
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=replace-me
VITE_AUTH0_AUDIENCE=https://api.brooksweb.uk
VITE_AUTH0_REDIRECT_URI=https://brooksweb.uk
VITE_PINS_API_URL=https://brooksweb.uk/api
VITE_MAP_PROVIDER=google
VITE_GOOGLE_MAPS_KEY=replace-me
VITE_LEAFLET_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_LEAFLET_ATTRIBUTION=&copy; OpenStreetMap
VITE_REVERSE_GEOCODE_URL=https://api.bigdatacloud.net/data/reverse-geocode-client
VITE_DEFAULT_CENTER_LAT=41.9028
VITE_DEFAULT_CENTER_LNG=12.4964
